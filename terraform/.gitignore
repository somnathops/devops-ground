.gitignore
# Terraform state files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable files that may contain secrets
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json